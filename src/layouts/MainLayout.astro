---
import "../styles/global.css";
import Header from "../components/share/Header.astro";
import Footer from "../components/share/Footer.astro";
import {SITE_AUTHOR, SITE_IMAGE} from "../utils/config/globals";

interface Props {
  title?: string;
  description?: string;
  socialImage?: string;
  year?: number;
  canonicalUrl?: string;
  keywords?: string[];
  ogType?: string;
  publishedDate?: string;
  author?: string;
  fullWidth?: boolean;
}

const currentYearChile = new Date().toLocaleString('es-CL', {
  timeZone: 'America/Santiago',
  year: 'numeric'
});

const {
  title = `Feriados de Chile ${currentYearChile}`,
  description = `Todos los feriados de Chile para el año ${currentYearChile} feriados legales, irrenunciables, locales, especiales, etc. Todos los feriados aquí.`,
  socialImage = SITE_IMAGE.src,
  year = parseInt(currentYearChile),
  canonicalUrl = Astro.url.href,
  keywords,
  ogType = 'website',
  publishedDate,
  author,
  fullWidth = false,
} = Astro.props;

const absoluteImage = socialImage?.startsWith('http')
  ? socialImage
  : `https://feriados-chile.com${socialImage}`;
---
<html lang="es">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width"/>

    <!-- Canonical & Sitemap -->
    <link rel="canonical" href={canonicalUrl}/>
    <link rel="sitemap" href="/sitemap-index.xml"/>
    <link rel="icon" type="image/icon" href="/favicon.ico"/>

    <!-- SEO básico -->
    <title>{title}</title>
    <meta name="description" content={description}/>
    <meta name="author" content={SITE_AUTHOR}/>
    <meta name="robots" content="index, follow"/>
    {keywords?.length && <meta name="keywords" content={keywords.join(', ')}/>}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType}/>
    {publishedDate && <meta property="article:published_time" content={publishedDate}/>}
    {author && <meta property="article:author" content={author}/>}
    <meta property="og:site_name" content="Feriados Chile"/>
    <meta property="og:url" content={canonicalUrl}/>
    <meta property="og:title" content={title}/>
    <meta property="og:description" content={description}/>
    <meta property="og:image" content={absoluteImage}/>
    <meta property="og:locale" content="es_CL"/>

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content={title}/>
    <meta name="twitter:description" content={description}/>
    <meta name="twitter:image" content={absoluteImage}/>

    <slot name="head"/>

    <script type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-3L1KYPN7S6"></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-3L1KYPN7S6');
    </script>
    </head>
<body>
{fullWidth ? (
  <div class="min-h-screen grid grid-rows-[auto_1fr_auto]">
    <div class="container mx-auto px-4 max-w-5xl pt-8">
      <Header year={year}/>
    </div>
    <main>
      <slot/>
    </main>
    <div class="container mx-auto px-4 max-w-5xl pb-8">
      <Footer/>
    </div>
  </div>
) : (
  <div class="min-h-screen grid grid-rows-[auto_1fr_auto] container mx-auto px-4 py-8 max-w-5xl">
    <Header year={year}/>
    <main>
      <slot/>
    </main>
    <Footer/>
  </div>
)}
</body>
</html>