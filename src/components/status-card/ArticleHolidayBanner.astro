---
import { actions } from "astro:actions";
import { getTodayDateChile, getDaysUntilHoliday } from "../../utils/dates/date";

const today = getTodayDateChile();

const { data: todayData, error: todayError } = await Astro.callAction(actions.TodayIsHoliday, today);
if (todayError) throw new Error(todayError.message);

const { isHoliday, holidays } = todayData;

let nextHoliday = null;
let daysRemaining = 0;

if (!isHoliday) {
  const { data: nextData } = await Astro.callAction(actions.NextHoliday, today);
  if (nextData?.hasNextHoliday && nextData.nextHoliday?.date) {
    nextHoliday = nextData.nextHoliday;
    daysRemaining = getDaysUntilHoliday(nextHoliday.date);
  }
}

const holiday = isHoliday ? holidays?.[0] : null;
---

{isHoliday && holiday ? (
  <a
    href="/"
    class="not-prose group flex items-center justify-between gap-3 w-full px-4 py-3 rounded-xl
           bg-emerald-50 border border-emerald-100 hover:bg-emerald-100/70
           transition-colors duration-200 ![text-decoration:none] hover:![text-decoration:none] animate-fade-in"
  >
    <div class="flex items-center gap-2.5 min-w-0">
      <span class="shrink-0 text-lg" aria-hidden="true">
        {holiday.icon ?? "✨"}
      </span>
      <span class="text-sm font-semibold text-emerald-800 truncate">
        Hoy es feriado:
        <span class="font-bold">{holiday.description}</span>
      </span>
    </div>
    <span class="shrink-0 text-xs font-medium text-emerald-600 group-hover:text-emerald-700 flex items-center gap-1">
      Ver todos
      <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
      </svg>
    </span>
  </a>
) : !isHoliday && nextHoliday ? (
  <a
    href="/"
    class="not-prose group flex items-center justify-between gap-3 w-full px-4 py-3 rounded-xl
           bg-amber-50 border border-amber-100 hover:bg-amber-100/70
           transition-colors duration-200 ![text-decoration:none] hover:![text-decoration:none] animate-fade-in"
  >
    <div class="flex items-center gap-2.5 min-w-0">
      <span class="shrink-0 text-lg" aria-hidden="true">
        {nextHoliday.icon ?? "📅"}
      </span>
      <span class="text-sm font-semibold text-amber-800 truncate">
        Próximo feriado:
        <span class="font-bold">{nextHoliday.description}</span>
      </span>
    </div>
    <span class="shrink-0 text-xs font-medium text-amber-600 group-hover:text-amber-700 flex items-center gap-1.5">
      <span class="tabular-nums font-bold text-amber-700">{daysRemaining}</span>
      {daysRemaining === 1 ? "día" : "días"}
      <svg class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
      </svg>
    </span>
  </a>
) : null}

<style>
  .animate-fade-in {
    animation: fadeIn 0.4s ease-out;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>